    <string name="tutorial_movement_grab_label">Ambil keping</string>
    <string name="tutorial_movement_grab_desc">Sentuh keping aktif dan seret secara horizontal untuk
        memindahkannya kolom demi kolom.</string>
    <string name="tutorial_movement_swipe_label">Geser bergerak</string>
    <string name="tutorial_movement_swipe_desc">Geser di tempat lain pada papan untuk memindahkan
        keping dengan DAS/ARR.</string>
    <string name="tutorial_movement_rotation_label">Rotasi</string>
    <string name="tutorial_movement_rotation_desc">Ketuk sisi kanan papan untuk memutar searah jarum
        jam, sisi kiri untuk berlawanan arah.</string>
    <string name="tutorial_dropping_soft_label">Jatuh pelan</string>
    <string name="tutorial_dropping_soft_desc">Seret perlahan ke bawah di tempat lain agar jatuh
        lebih cepat (+1 poin/baris).</string>
    <string name="tutorial_dropping_hard_label">Jatuh cepat</string>
    <string name="tutorial_dropping_hard_desc">Jentik cepat ke bawah untuk mengunci seketika (+2
        poin/baris).</string>
    <string name="tutorial_dropping_delay_label">Tunda jatuh</string>
    <string name="tutorial_dropping_delay_desc">Geser ke atas untuk membekukan gravitasi sementara
        (sekali per keping).</string>
    <string name="tutorial_strategy_hold_label">Simpan</string>
    <string name="tutorial_strategy_hold_desc">Ketuk panel SIMPAN atau tombol untuk menukar keping
        aktif agar dipakai nanti.</string>
    <string name="tutorial_strategy_ghost_label">Keping bayangan</string>
    <string name="tutorial_strategy_ghost_desc">Lihat proyeksi di lantai untuk mengetahui tepat di
        mana keping akan mendarat.</string>
    <string name="tutorial_strategy_queue_label">Antrean berikutnya</string>
    <string name="tutorial_strategy_queue_desc">Antrean di kanan menampilkan keping yang akan
        datang. Antrean mengecil saat level naik!</string>
    <string name="tutorial_scoring_lines_label">Hapus baris</string>
    <string name="tutorial_scoring_lines_desc">Hapus baris untuk mencetak skor! Pengali level
        berlaku untuk semua hapusan.</string>
    <string name="tutorial_scoring_tspin_label">T-Spin</string>
    <string name="tutorial_scoring_tspin_desc">Putar keping T ke celah sempit untuk bonus poin
        besar.</string>
    <string name="tutorial_scoring_combos_label">Kombo</string>
    <string name="tutorial_scoring_combos_desc">Hapus baris dalam penempatan beruntun untuk
        membangun pengali kombo.</string>
    <string name="tutorial_scoring_allclear_label">Bersih total</string>
    <string name="tutorial_scoring_allclear_desc">Kosongkan seluruh papan untuk hadiah skor
        tertinggi.</string>
