    <string name="tutorial_movement_grab_label">抓取方块</string>
    <string name="tutorial_movement_grab_desc">触摸活动方块并水平拖动，可逐列移动。</string>
    <string name="tutorial_movement_swipe_label">滑动移动</string>
    <string name="tutorial_movement_swipe_desc">在棋盘其他位置滑动，可用 DAS/ARR 移动方块。</string>
    <string name="tutorial_movement_rotation_label">旋转</string>
    <string name="tutorial_movement_rotation_desc">点击棋盘右半边顺时针旋转，点击左半边逆时针旋转。</string>
    <string name="tutorial_dropping_soft_label">软降</string>
    <string name="tutorial_dropping_soft_desc">在其他位置缓慢向下拖动可加速下落（+1 分/行）。</string>
    <string name="tutorial_dropping_hard_label">硬降</string>
    <string name="tutorial_dropping_hard_desc">快速向下轻扫可立即锁定（+2 分/行）。</string>
    <string name="tutorial_dropping_delay_label">延迟下落</string>
    <string name="tutorial_dropping_delay_desc">向上滑动可暂时冻结重力（每个方块一次）。</string>
    <string name="tutorial_strategy_hold_label">暂存</string>
    <string name="tutorial_strategy_hold_desc">点击暂存面板或按钮，将活动方块交换到以后使用。</string>
    <string name="tutorial_strategy_ghost_label">幽灵方块</string>
    <string name="tutorial_strategy_ghost_desc">观察底部投影，准确看到方块将落在哪里。</string>
    <string name="tutorial_strategy_queue_label">下一个队列</string>
    <string name="tutorial_strategy_queue_desc">右侧队列显示即将出现的方块。升级后它会缩短！</string>
    <string name="tutorial_scoring_lines_label">消除行</string>
    <string name="tutorial_scoring_lines_desc">消除整行来得分！等级倍率适用于所有消除。</string>
    <string name="tutorial_scoring_tspin_label">T-Spin</string>
    <string name="tutorial_scoring_tspin_desc">把 T 方块旋入狭窄位置可获得大量奖励分。</string>
    <string name="tutorial_scoring_combos_label">连击</string>
    <string name="tutorial_scoring_combos_desc">连续放置并消除行可累积连击倍率。</string>
    <string name="tutorial_scoring_allclear_label">全清</string>
    <string name="tutorial_scoring_allclear_desc">清空整个棋盘，获得最高分数奖励。</string>
