    <string name="tutorial_movement_grab_label">Chwytanie bloku</string>
    <string name="tutorial_movement_grab_desc">Dotknij aktywnego bloku i przesuń poziomo, aby przesuwać kolumnami.</string>
    <string name="tutorial_movement_swipe_label">Przesuń palcem</string>
    <string name="tutorial_movement_swipe_desc">Przesuń w dowolnym innym miejscu planszy, aby poruszać się z DAS/ARR.</string>
    <string name="tutorial_movement_rotation_label">Obrót</string>
    <string name="tutorial_movement_rotation_desc">Stuknij w prawą połowę planszy, aby obrócić zgodnie z ruchem wskazówek, w lewą dla przeciwnie.</string>

    <string name="tutorial_dropping_soft_label">Łagodne opadanie</string>
    <string name="tutorial_dropping_soft_desc">Powoli przeciągnij w dół w dowolnym innym miejscu, aby szybciej spaść (+1 pkt/wiersz).</string>
    <string name="tutorial_dropping_hard_label">Twardy spadek</string>
    <string name="tutorial_dropping_hard_desc">Szybko przesuń w dół, aby natychmiast zatwierdzić (+2 pkt/wiersz).</string>
    <string name="tutorial_dropping_delay_label">Opóźnienie spadku</string>
    <string name="tutorial_dropping_delay_desc">Przesuń w górę, aby tymczasowo zatrzymać grawitację (raz na figurę).</string>

    <string name="tutorial_strategy_hold_label">Przechowanie</string>
    <string name="tutorial_strategy_hold_desc">Stuknij panel TRZYMAJ lub przycisk, aby zamienić aktywną figurę na później.</string>
    <string name="tutorial_strategy_ghost_label">Widmo</string>
    <string name="tutorial_strategy_ghost_desc">Obserwuj projekcję na podłodze, aby wiedzieć, gdzie dokładnie wyląduje figura.</string>
    <string name="tutorial_strategy_queue_label">Kolejka</string>
    <string name="tutorial_strategy_queue_desc">Kolejka po prawej pokazuje nadchodzące figury. Kurczy się wraz z awansami poziomu.</string>

    <string name="tutorial_scoring_lines_label">Usuwanie linii</string>
    <string name="tutorial_scoring_lines_desc">Usuń rzędy, aby zdobyć wynik! Mnożnik poziomu dotyczy wszystkich.</string>
    <string name="tutorial_scoring_tspin_label">T-Spiny</string>
    <string name="tutorial_scoring_tspin_desc">Wsuń figurę T w ciasne miejsce, aby uzyskać ogromny bonus.</string>
    <string name="tutorial_scoring_combos_label">Kombinacje</string>
    <string name="tutorial_scoring_combos_desc">Zbijaj rzędy jeden po drugim, aby zwiększyć mnożnik combo.</string>
    <string name="tutorial_scoring_allclear_label">Czyszczenie</string>
    <string name="tutorial_scoring_allclear_desc">Wyczyść całą planszę, aby zdobyć maksymalny bonus.</string>
