    <string name="tutorial_got_it">CAPITO!</string>
    <string name="tutorial_movement_grab_label">Afferra pezzo</string>
    <string name="tutorial_movement_grab_desc">Tocca il pezzo attivo e trascinalo orizzontalmente
        per muoverlo colonna per colonna.</string>
    <string name="tutorial_movement_swipe_label">Muovi con swipe</string>
    <string name="tutorial_movement_swipe_desc">Scorri in qualsiasi altro punto del tabellone per
        muovere i pezzi con DAS/ARR.</string>
    <string name="tutorial_movement_rotation_label">Rotazione</string>
    <string name="tutorial_movement_rotation_desc">Tocca la metà destra del tabellone per ruotare in
        senso orario, la sinistra per antiorario.</string>
    <string name="tutorial_dropping_soft_label">Caduta morbida</string>
    <string name="tutorial_dropping_soft_desc">Trascina lentamente verso il basso altrove per cadere
        più veloce (+1 pt/riga).</string>
    <string name="tutorial_dropping_hard_label">Caduta rapida</string>
    <string name="tutorial_dropping_hard_desc">Scorri rapidamente verso il basso per bloccare subito
        (+2 pt/riga).</string>
    <string name="tutorial_dropping_delay_label">Ritardo caduta</string>
    <string name="tutorial_dropping_delay_desc">Scorri verso l’alto per fermare temporaneamente la
        gravità (una volta per pezzo).</string>
    <string name="tutorial_strategy_hold_label">Riserva</string>
    <string name="tutorial_strategy_hold_desc">Tocca il pannello RISERVA o il pulsante per scambiare
        il pezzo attivo per usarlo dopo.</string>
    <string name="tutorial_strategy_ghost_label">Pezzo fantasma</string>
    <string name="tutorial_strategy_ghost_desc">Guarda la proiezione sul fondo per vedere
        esattamente dove atterrerà il pezzo.</string>
    <string name="tutorial_strategy_queue_label">Coda successiva</string>
    <string name="tutorial_strategy_queue_desc">La coda a destra mostra i prossimi pezzi. Si
        accorcia quando sali di livello!</string>
    <string name="tutorial_scoring_lines_label">Linee eliminate</string>
    <string name="tutorial_scoring_lines_desc">Elimina righe per fare punti! Il moltiplicatore di
        livello vale per tutte.</string>
    <string name="tutorial_scoring_tspin_label">T-Spin</string>
    <string name="tutorial_scoring_tspin_desc">Ruota un pezzo T in uno spazio stretto per un grande
        bonus.</string>
    <string name="tutorial_scoring_combos_label">Combo</string>
    <string name="tutorial_scoring_combos_desc">Elimina linee in piazzamenti consecutivi per creare
        un moltiplicatore combo.</string>
    <string name="tutorial_scoring_allclear_label">Tutto pulito</string>
    <string name="tutorial_scoring_allclear_desc">Svuota tutto il tabellone per la ricompensa
        definitiva.</string>
