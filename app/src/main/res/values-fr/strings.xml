    <string name="tutorial_movement_grab_label">Saisir la pièce</string>
    <string name="tutorial_movement_grab_desc">Touchez la pièce active et faites-la glisser
        horizontalement pour la déplacer colonne par colonne.</string>
    <string name="tutorial_movement_swipe_label">Déplacement par glissement</string>
    <string name="tutorial_movement_swipe_desc">Faites glisser ailleurs sur le plateau pour déplacer
        les pièces avec DAS/ARR.</string>
    <string name="tutorial_movement_rotation_label">Rotation</string>
    <string name="tutorial_movement_rotation_desc">Touchez la moitié droite du plateau pour tourner
        dans le sens horaire, la moitié gauche pour l’inverse.</string>
    <string name="tutorial_dropping_soft_label">Chute douce</string>
    <string name="tutorial_dropping_soft_desc">Glissez lentement vers le bas ailleurs pour tomber
        plus vite (+1 pt/ligne).</string>
    <string name="tutorial_dropping_hard_label">Chute rapide</string>
    <string name="tutorial_dropping_hard_desc">Faites un geste rapide vers le bas pour verrouiller
        instantanément (+2 pts/ligne).</string>
    <string name="tutorial_dropping_delay_label">Délai de chute</string>
    <string name="tutorial_dropping_delay_desc">Glissez vers le haut pour figer temporairement la
        gravité (une fois par pièce).</string>
    <string name="tutorial_strategy_hold_label">Réserve</string>
    <string name="tutorial_strategy_hold_desc">Touchez le panneau RÉSERVE ou le bouton pour échanger
        la pièce active pour plus tard.</string>
    <string name="tutorial_strategy_ghost_label">Pièce fantôme</string>
    <string name="tutorial_strategy_ghost_desc">Regardez la projection au sol pour voir exactement
        où votre pièce atterrira.</string>
    <string name="tutorial_strategy_queue_label">File suivante</string>
    <string name="tutorial_strategy_queue_desc">La file à droite affiche les prochaines pièces. Elle
        rétrécit quand vous montez de niveau !</string>
    <string name="tutorial_scoring_lines_label">Lignes effacées</string>
    <string name="tutorial_scoring_lines_desc">Effacez des lignes pour marquer ! Le multiplicateur
        de niveau s’applique à toutes.</string>
    <string name="tutorial_scoring_tspin_label">T-Spins</string>
    <string name="tutorial_scoring_tspin_desc">Faites pivoter une pièce T dans un espace étroit pour
        un gros bonus.</string>
    <string name="tutorial_scoring_combos_label">Combos</string>
    <string name="tutorial_scoring_combos_desc">Effacez des lignes sur des placements consécutifs
        pour créer un multiplicateur de combo.</string>
    <string name="tutorial_scoring_allclear_label">Tout effacé</string>
    <string name="tutorial_scoring_allclear_desc">Videz tout le plateau pour obtenir la récompense
        ultime.</string>
