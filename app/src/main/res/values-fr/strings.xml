    <string name="tutorial_music_set_folder_label">Définir le dossier musique</string>
    <string name="tutorial_music_set_folder_desc">Ouvrez Paramètres, entrez dans Bibliothèque
        musicale, touchez Définir le dossier musique, puis choisissez le dossier contenant vos
        fichiers .mod / .xm / .s3m / .it.</string>
    <string name="tutorial_music_set_main_label">Choisir le thème principal</string>
    <string name="tutorial_music_set_main_desc">Après le scan, choisissez une piste dans
        Bibliothèque musicale et touchez Définir comme thème principal si vous voulez un lancement
        automatique avec une nouvelle partie.</string>
    <string name="tutorial_music_download_label">Où obtenir des Mods</string>
    <string name="tutorial_music_download_desc">Sources exemples : The Mod Archive (modarchive.org)
        et scene.org (files.scene.org). Téléchargez des fichiers de modules, puis placez-les dans
        Download/Mods/ ou dans votre dossier de musique sélectionné.</string>
