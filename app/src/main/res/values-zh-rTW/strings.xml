    <string name="tutorial_movement_grab_label">抓取方塊</string>
    <string name="tutorial_movement_grab_desc">觸碰作用中的方塊並水平拖曳，即可逐欄移動。</string>
    <string name="tutorial_movement_swipe_label">滑動移動</string>
    <string name="tutorial_movement_swipe_desc">在棋盤其他位置滑動，可用 DAS/ARR 移動方塊。</string>
    <string name="tutorial_movement_rotation_label">旋轉</string>
    <string name="tutorial_movement_rotation_desc">點選棋盤右半部可順時針旋轉，左半部可逆時針旋轉。</string>
    <string name="tutorial_dropping_soft_label">軟降</string>
    <string name="tutorial_dropping_soft_desc">在其他位置慢慢向下拖曳，可加速下落（+1 分/列）。</string>
    <string name="tutorial_dropping_hard_label">硬降</string>
    <string name="tutorial_dropping_hard_desc">快速向下滑動可立即鎖定（+2 分/列）。</string>
    <string name="tutorial_dropping_delay_label">延遲下落</string>
    <string name="tutorial_dropping_delay_desc">向上滑動可暫時凍結重力（每個方塊一次）。</string>
    <string name="tutorial_strategy_hold_label">保留</string>
    <string name="tutorial_strategy_hold_desc">點選保留面板或按鈕，將作用中的方塊交換到稍後使用。</string>
    <string name="tutorial_strategy_ghost_label">幽靈方塊</string>
    <string name="tutorial_strategy_ghost_desc">觀察底部投影，即可準確看到方塊會落在哪裡。</string>
    <string name="tutorial_strategy_queue_label">下一個佇列</string>
    <string name="tutorial_strategy_queue_desc">右側佇列會顯示接下來的方塊。升級後它會縮短！</string>
    <string name="tutorial_scoring_lines_label">消除行</string>
    <string name="tutorial_scoring_lines_desc">消除整行來得分！等級倍率會套用到所有消除。</string>
    <string name="tutorial_scoring_tspin_label">T-Spin</string>
    <string name="tutorial_scoring_tspin_desc">將 T 方塊旋入狹窄位置可獲得大量獎勵分。</string>
    <string name="tutorial_scoring_combos_label">連擊</string>
    <string name="tutorial_scoring_combos_desc">連續放置並消除行可累積連擊倍率。</string>
    <string name="tutorial_scoring_allclear_label">全清</string>
    <string name="tutorial_scoring_allclear_desc">清空整個棋盤，取得最高分數獎勵。</string>
