    <string name="tutorial_movement_grab_label">Agarrar peça</string>
    <string name="tutorial_movement_grab_desc">Toque na peça ativa e arraste horizontalmente para
        movê-la coluna por coluna.</string>
    <string name="tutorial_movement_swipe_label">Mover com deslize</string>
    <string name="tutorial_movement_swipe_desc">Deslize em qualquer outro ponto do tabuleiro para
        mover peças com DAS/ARR.</string>
    <string name="tutorial_movement_rotation_label">Rotação</string>
    <string name="tutorial_movement_rotation_desc">Toque na metade direita do tabuleiro para girar
        no sentido horário, ou na esquerda para anti-horário.</string>
    <string name="tutorial_dropping_soft_label">Queda suave</string>
    <string name="tutorial_dropping_soft_desc">Arraste lentamente para baixo em outro ponto para
        cair mais rápido (+1 pt/linha).</string>
    <string name="tutorial_dropping_hard_label">Queda rápida</string>
    <string name="tutorial_dropping_hard_desc">Deslize rapidamente para baixo para travar na hora
        (+2 pts/linha).</string>
    <string name="tutorial_dropping_delay_label">Atraso da queda</string>
    <string name="tutorial_dropping_delay_desc">Deslize para cima para congelar a gravidade
        temporariamente (uma vez por peça).</string>
    <string name="tutorial_strategy_hold_label">Guardar</string>
    <string name="tutorial_strategy_hold_desc">Toque no painel GUARDAR ou no botão para trocar a
        peça ativa para usar depois.</string>
    <string name="tutorial_strategy_ghost_label">Peça fantasma</string>
    <string name="tutorial_strategy_ghost_desc">Observe a projeção no chão para ver exatamente onde
        sua peça vai cair.</string>
    <string name="tutorial_strategy_queue_label">Fila seguinte</string>
    <string name="tutorial_strategy_queue_desc">A fila à direita mostra as próximas peças. Ela
        diminui conforme você sobe de nível!</string>
    <string name="tutorial_scoring_lines_label">Linhas removidas</string>
    <string name="tutorial_scoring_lines_desc">Remova linhas para pontuar! O multiplicador de nível
        vale para todas.</string>
    <string name="tutorial_scoring_tspin_label">T-Spins</string>
    <string name="tutorial_scoring_tspin_desc">Gire uma peça T em um espaço apertado para ganhar
        muitos pontos bônus.</string>
    <string name="tutorial_scoring_combos_label">Combos</string>
    <string name="tutorial_scoring_combos_desc">Remova linhas em posicionamentos consecutivos para
        criar um multiplicador de combo.</string>
    <string name="tutorial_scoring_allclear_label">Tudo limpo</string>
    <string name="tutorial_scoring_allclear_desc">Esvazie todo o tabuleiro para ganhar a recompensa
        máxima.</string>
