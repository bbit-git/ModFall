    <string name="tutorial_music_set_folder_label">Definir pasta de música</string>
    <string name="tutorial_music_set_folder_desc">Abra Configurações, entre na Biblioteca de música,
        toque em Definir pasta de música e escolha a pasta que contém seus arquivos .mod / .xm /
        .s3m / .it.</string>
    <string name="tutorial_music_set_main_label">Escolher tema principal</string>
    <string name="tutorial_music_set_main_desc">Depois da verificação, escolha uma faixa na
        Biblioteca de música e toque em Definir como tema principal se quiser que ela comece
        automaticamente com um novo jogo.</string>
    <string name="tutorial_music_download_label">Onde obter Mods</string>
    <string name="tutorial_music_download_desc">Fontes de exemplo: The Mod Archive (modarchive.org)
        e scene.org (files.scene.org). Baixe arquivos de módulo lá e coloque-os em Download/Mods/ ou
        na pasta de música selecionada.</string>
